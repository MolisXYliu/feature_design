{
  "name": "CMBDevClaw",
  "version": "0.2.0",
  "description": "CMBDevClaw description",
  "author": {
    "name": "CMBDevClaw",
    "email": "dev@cmbdevclaw.com"
  },
  "main": "./out/main/index.js",
  "files": [
    "out/",
    "bin/",
    "resources/",
    "skills/",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "openwork": "./bin/cli.js"
  },
  "license": "MIT",
  "keywords": [
    "ai",
    "agent",
    "electron",
    "deepagents",
    "langchain",
    "langgraph",
    "desktop"
  ],
  "engines": {
    "node": ">=18 <24"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "clean:win-code-exe": "node -e \"require('fs').rmSync('resources/bin/win32/codex.exe', { force: true })\"",
    "predist": "npm run clean:win-code-exe",
    "predist:win": "npm run clean:win-code-exe",
    "predist:mac": "npm run clean:win-code-exe",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "server:cache": "node scripts/server-cache.js",
    "postinstall": "electron-rebuild -f -w node-pty",
    "env:filter:setup": "node scripts/setup-env-filter.mjs",
    "env:encrypt": "node scripts/env-crypt.mjs encrypt-file .env",
    "env:decrypt": "node scripts/env-crypt.mjs decrypt-file .env",
    "env:encrypt:quick": "git add --renormalize .env && git show :.env | head -n 1",
    "env:decrypt:quick": "rm -f .env && git checkout -- .env",
    "env:filter:disable": "git config --local --unset filter.envcrypt.clean; git config --local --unset filter.envcrypt.smudge; git config --local --unset filter.envcrypt.required"
  },
  "build": {
    "appId": "com.cmbdevclaw.com",
    "productName": "CMBDevClaw",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/",
      "node_modules/",
      "package.json"
    ],
    "asarUnpack": [
      "out/main/pty-host.js",
      "node_modules/.bin/claude*",
      "node_modules/node-pty/**",
      "node_modules/@anthropic-ai/claude-code/**"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "dir",
      "afterPack": "scripts/after-pack.js"
    },
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin"
      }
    ],
    "electronVersion": "39.8.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.92",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/rajdhani": "^5.2.7",
    "@langchain/anthropic": "^1.3.21",
    "@langchain/core": "^1.1.29",
    "@langchain/google-genai": "^2.1.22",
    "@langchain/langgraph": "^1.2.0",
    "@langchain/langgraph-checkpoint": "^1.0.0",
    "@langchain/langgraph-sdk": "^1.6.5",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.2.11",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.5.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "deepagents": "^1.8.1",
    "electron-store": "^8.2.0",
    "fast-glob": "^3.3.3",
    "iconv-lite": "^0.7.2",
    "jschardet": "^3.1.4",
    "langchain": "^1.2.28",
    "lucide-react": "^0.469.0",
    "mammoth": "1.12.0",
    "micromatch": "^4.0.8",
    "node-pty": "^1.1.0",
    "playwright": "^1.58.2",
    "react-diff-viewer-continued": "^4.1.2",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.4.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "segment": "^0.1.3",
    "shiki": "^3.21.0",
    "sonner": "^2.0.7",
    "sql.js": "^1.12.0",
    "tailwind-merge": "^2.6.0",
    "uuid": "^11.0.5",
    "ws": "^8.19.0",
    "xlsx": "0.18.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
